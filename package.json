{
  "name": "anthropic-oauth",
  "version": "0.1.0",
  "type": "module",
  "engines": { "bun": ">=1.3.12" },
  "exports": { ".": "./src/index.ts", "./server": "./src/plugin.ts", "./plugin": "./src/plugin.ts" },
  "scripts": {
    "dev": "bun run bin/cli.ts",
    "sync": "bun run bin/sync-to-opencode.ts",
    "build": "bun build ./src/index.ts --target=bun --outdir ./dist",
    "test": "bun test",
    "typecheck": "bunx --bun tsc --noEmit",
    "format": "bunx --bun dprint fmt",
    "format:check": "bunx --bun dprint check",
    "lint": "bun run typecheck && bun run format:check",
    "ci": "bun run lint && bun run test && bun run build"
  },
  "dependencies": { "@openauthjs/openauth": "0.4.3", "effect": "3.21.0" },
  "devDependencies": { "@types/bun": "1.3.12", "dprint": "0.54.0", "typescript": "6.0.2" }
}
